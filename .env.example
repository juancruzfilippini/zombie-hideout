# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=es

# Database
DATABASE_URL=mysql://root:root@localhost:3306/zombie_hideout

# Server status
SERVER_STATUS_MODE=auto
SERVER_STATUS_ALLOW_MOCK_IN_PRODUCTION=false
SERVER_QUERY_TIMEOUT_MS=3500

# Contact
CONTACT_EMAIL_TO=
EMAIL_PROVIDER_API_KEY=
EMAIL_PROVIDER_MODE=log

# Payments
PAYMENTS_MOCK_ENABLED=true
PAYMENT_SUCCESS_URL=http://localhost:3000/es/donar?status=success
PAYMENT_PENDING_URL=http://localhost:3000/es/donar?status=pending
PAYMENT_FAILURE_URL=http://localhost:3000/es/donar?status=failure

# Mercado Pago Checkout Pro
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_SANDBOX=true

# PayPal Checkout
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox

# Binance Pay API v3
BINANCE_PAY_API_KEY=
BINANCE_PAY_SECRET_KEY=
BINANCE_PAY_MERCHANT_ID=
BINANCE_PAY_SANDBOX=true
BINANCE_PAY_ENABLED=false

# Optional manual transfer fallback
DONATION_MANUAL_QR_URL=
